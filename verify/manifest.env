MODE="docker-compose"
PORT="8010"
BOARD="projects"
UP='docker compose up -d --build'
DOWN='docker compose down -v'
READY='curl -sf http://localhost:$PORT/healthz'
LOGS='docker compose logs --tail=50'
TEST_DEPS='httpx pytest'
ACCEPTANCE='API_BASE_URL="http://localhost:$PORT" "$PY" -m pytest verify/acceptance -v'
